# Required — all must be set (no defaults in code). Copy to .env.local and fill in.
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_SITE_NAME=
NEXT_PUBLIC_SITE_DESCRIPTION=
NEXT_PUBLIC_NFT_ADDRESS=
NEXT_PUBLIC_MARKET_ADDRESS=
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_RWALK_BASE_URL=
# Public base for RandomWalk media (browser loads these directly). Example Go static: http://127.0.0.1:9090/images/randomwalk (requires websrv NFT_ASSETS_ROOT).
NEXT_PUBLIC_ASSET_BASE_URL=

# Optional — WalletConnect (leave empty for injected-wallet-only)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
