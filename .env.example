# The app refuses to start unless all three are set in the process environment (e.g. export in the
# shell before `pnpm dev`, or your host’s env settings). Values below are placeholders only.
#
# NEXT_PUBLIC_NETWORK — one of: local | sepolia | mainnet
NEXT_PUBLIC_NETWORK=
# NEXT_PUBLIC_API_BASE_URL — Go webserv origin, no trailing slash (RandomWalk API + images are derived)
NEXT_PUBLIC_API_BASE_URL=
# NEXT_PUBLIC_RPC_URL — JSON-RPC HTTP URL for viem/wagmi (your node)
NEXT_PUBLIC_RPC_URL=

# Optional — block explorer base for links (defaults per network preset)
# NEXT_PUBLIC_BLOCK_EXPLORER_URL=

# Optional — canonical site URL (default: http://localhost:3000 or https://$VERCEL_URL)
# NEXT_PUBLIC_SITE_URL=

# Optional — branding (defaults in src/lib/config.ts)
# NEXT_PUBLIC_SITE_NAME=
# NEXT_PUBLIC_SITE_DESCRIPTION=

# Optional — on sepolia/mainnet only: if both set, contract addresses skip the API (e.g. tests).
# With NEXT_PUBLIC_NETWORK=local, next.config strips these so the client uses API-loaded addresses.
# NEXT_PUBLIC_NFT_ADDRESS=
# NEXT_PUBLIC_MARKET_ADDRESS=

# Optional — WalletConnect (empty = injected-wallet only)
# NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
